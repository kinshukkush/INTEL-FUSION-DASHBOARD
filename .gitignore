# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ───────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js build output ────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Testing ─────────────────────────────────────────────────────────────────
/coverage

# ─── Environment variables ───────────────────────────────────────────────────
# Never commit secrets. Use Vercel's dashboard for environment variables.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel

# ─── OS & editor junk ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Debug logs ──────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Project notes (not for deployment) ──────────────────────────────────────
PROJECT_RULES.md
summery.md
NOTES.md
TODO.md